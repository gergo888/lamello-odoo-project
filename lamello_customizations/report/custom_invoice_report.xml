<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_inherited" inherit_id="l10n_hu_edi.report_invoice_document">
        <xpath expr="//table[@name='invoice_line_table']/tbody" position="attributes">
            <attribute name="t-if">o.account_template_type != 'export'</attribute>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']" position="inside">
            <tbody t-if="o.account_template_type == 'export'" class="invoice_tbody">
                <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang or o.env.user.lang)"/>
                <t t-set="display_discount" t-value="any(l.discount for l in o.invoice_line_ids)"/>
                <t t-set="display_taxes" t-value="any(l.tax_ids for l in o.invoice_line_ids)"/>
                <!--
                <t t-set="lines_to_report" t-value="o._get_move_lines_to_report().sorted(key=lambda l: l.sale_line_ids.order_id.name or '')"/>
                -->                
                <t t-set="lines_to_report" t-value="o._get_move_lines_to_report()"/>

                <!--
                <t t-set="orders" t-value="lines_to_report.mapped('sale_line_ids.order_id')"/>
                -->
                <t t-set="orders_with_ref" t-value="lines_to_report.mapped('sale_line_ids.order_id').filtered(lambda r: r.client_order_ref)"/>
                <t t-set="current_section" t-value="None"/>
                <t t-set="current_subsection" t-value="None"/>


                <!-- order szerinti csoportosítással -->
                <t t-foreach="orders_with_ref" t-as="order">
                    <!--
                    <tr class="bg-light fw-bold">
                        <td colspan="99" style="background-color: #f8f9fa !important; border-top: 1px solid #dee2e6;">
                            <strong>Rendelés: </strong>
                            <t t-out="order.name if order else 'Közvetlen tételek'"/>
                            <t t-if="order and order.client_order_ref">
                                <span class="ms-3 text-muted">(Ref: <t t-out="order.client_order_ref"/>)</span>
                            </t>
                        </td>
                    </tr>
                    -->
                    <tr t-if="order.client_order_ref" class="o_line_section">
                        <td colspan="99" class="bg-secondary" name="order_info">
                            <span class="ms-1" t-field="order.client_order_ref"/>
                        </td>
                    </tr>

                    <t t-foreach="lines_to_report.filtered(lambda l: l.sale_line_ids.order_id == order)" t-as="line">
                        <t t-set="is_note" t-value="line.display_type == 'line_note'"/>
                        <t t-set="is_section" t-value="line.display_type == 'line_section'"/>
                        <t t-set="is_subsection" t-value="line.display_type == 'line_subsection'"/>
                        <t t-set="is_product" t-value="line.display_type not in ('line_note', 'line_section', 'line_subsection')"/>

                        <t t-if="is_section">
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subsection" t-value="None"/>
                            <t t-set="line_padding" t-value="0"/>
                        </t>
                        <t t-elif="is_subsection">
                            <t t-set="current_subsection" t-value="line"/>
                            <t t-set="line_padding" t-value="3"/>
                        </t>
                        <t t-else="">
                            <t t-set="line_padding" t-value="4 if current_subsection else (2 if current_section else 0)"/>
                        </t>
                        
                        <t t-set="padding_class" t-value="line_padding and ('ps-' + str(line_padding)) or ''"/>
                        <t t-set="hide_details" t-value="line.collapse_composition"/>
                        <t t-set="hide_prices" t-value="line.collapse_prices"/>

                        <t t-if="not hide_details">
                            <tr t-att-class="'fw-bolder o_line_section' if is_section else 'fw-bold o_line_subsection' if is_subsection else 'fst-italic o_line_note' if is_note else ''">
                                
                                <t t-if="is_product">
                                    
                                    <!--
                                    <td name="account_invoice_line_name" t-att-class="padding_class">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    -->

                                    <td name="account_invoice_line_name" t-att-class="padding_class">

                                        <!--
                                        <t t-set="display_name" t-value="line.product_id.invoicing_name or line.name or ''"/>
                                        <span t-out="('—— ' if line.sale_line_ids[:1].linked_line_id else '') + display_name" t-options="{'widget': 'text'}"/>
                                        -->
                                        
                                        <t t-set="used_name" t-value="line.product_id.invoice_name or line.product_id.product_tmpl_id.invoice_name or line.product_id.product_tmpl_id.name or ''"/>

                                        <t t-if="line.product_id.default_code">
                                            <t t-set="product_name" t-value="'[' + (line.product_id.default_code or '') + '] ' + used_name"/>
                                        </t>

                                        <t t-if="not line.product_id.default_code">
                                            <t t-set="product_name" t-value="used_name"/>
                                        </t>
                                        <span t-out="('-- ' if line.sale_line_ids[:1].linked_line_id else '') + product_name" t-options="{'widget': 'text'}"/>

                                    </td>

                                    <td class="text-end">
                                        <span t-out="line.quantity * (sign or 1)"/>
                                        <span t-field="line.product_uom_id" groups="uom.group_uom"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-if="not hide_prices" t-field="line.price_unit"/>
                                    </td>
                                    <td t-if="display_discount" class="text-end">
                                        <span t-field="line.discount"/>%
                                    </td>

                                    <t t-set="taxes" t-value="', '.join(tax.tax_label for tax in line.tax_ids if tax.tax_label)"/>
                                    <td name="td_taxes" t-if="display_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                        <span t-if="not hide_prices" t-out="taxes" id="line_tax_ids">Tax 15%</span>
                                    </td>
                                    
                                    <td class="text-end o_price_total">
                                        <span t-if="not hide_prices" t-out="line.price_subtotal * (sign or 1)" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </t>

                                <t t-elif="is_section or is_subsection">
                                    <td colspan="99" t-att-class="padding_class">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>

                                <t t-elif="is_note">
                                    <td colspan="99" class="ps-5">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>
                            <!--
                            <tr t-if="is_product and line.product_id.invoice_name">
                                <td t-att-class="padding_class" colspan="99">
                                    <span t-field="line.product_id.invoice_name"/>
                                </td>
                            </tr>
                            -->
                        </t>
                    </t>
                </t>
                
                <!-- order szerinti csoportosítás nélkül -->
                <t t-set="no_ref_lines" t-value="lines_to_report.filtered(lambda l: not l.sale_line_ids.order_id or not l.sale_line_ids.order_id.client_order_ref)"/>

                <t t-if="no_ref_lines">
                    <tr t-if="orders_with_ref">
                        <td colspan="99" style="height: 20px;"></td> 
                    </tr>
                    <t t-foreach="no_ref_lines" t-as="line">

                        <t t-set="is_note" t-value="line.display_type == 'line_note'"/>
                        <t t-set="is_section" t-value="line.display_type == 'line_section'"/>
                        <t t-set="is_subsection" t-value="line.display_type == 'line_subsection'"/>
                        <t t-set="is_product" t-value="line.display_type not in ('line_note', 'line_section', 'line_subsection')"/>

                        <t t-if="is_section">
                            <t t-set="current_section" t-value="line"/>
                            <t t-set="current_subsection" t-value="None"/>
                            <t t-set="line_padding" t-value="0"/>
                        </t>
                        <t t-elif="is_subsection">
                            <t t-set="current_subsection" t-value="line"/>
                            <t t-set="line_padding" t-value="3"/>
                        </t>
                        <t t-else="">
                            <t t-set="line_padding" t-value="4 if current_subsection else (2 if current_section else 0)"/>
                        </t>
                        
                        <t t-set="padding_class" t-value="line_padding and ('ps-' + str(line_padding)) or ''"/>
                        <t t-set="hide_details" t-value="line.collapse_composition"/>
                        <t t-set="hide_prices" t-value="line.collapse_prices"/>

                        <t t-if="not hide_details">
                            <tr t-att-class="'fw-bolder o_line_section' if is_section else 'fw-bold o_line_subsection' if is_subsection else 'fst-italic o_line_note' if is_note else ''">
                                
                                <t t-if="is_product">

                                    <td name="account_invoice_line_name" t-att-class="padding_class">

                                        <!--
                                        <t t-set="display_name" t-value="line.product_id.invoicing_name or line.name or ''"/>
                                        <span t-out="('—— ' if line.sale_line_ids[:1].linked_line_id else '') + display_name" t-options="{'widget': 'text'}"/>
                                        -->
                                        <t t-set="used_name" t-value="line.product_id.invoice_name or line.product_id.product_tmpl_id.invoice_name or line.product_id.product_tmpl_id.name or ''"/>

                                        <t t-if="line.product_id.default_code">
                                            <t t-set="product_name" t-value="'[' + (line.product_id.default_code or '') + '] ' + used_name"/>
                                        </t>

                                        <t t-if="not line.product_id.default_code">
                                            <t t-set="product_name" t-value="used_name"/>
                                        </t>

                                        <span t-out="('-- ' if line.sale_line_ids[:1].linked_line_id else '') + product_name" t-options="{'widget': 'text'}"/>

                                    </td>

                                    <td class="text-end">
                                        <span t-out="line.quantity * (sign or 1)"/>
                                        <span t-field="line.product_uom_id" groups="uom.group_uom"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-if="not hide_prices" t-field="line.price_unit"/>
                                    </td>
                                    <td t-if="display_discount" class="text-end">
                                        <span t-field="line.discount"/>%
                                    </td>

                                    <t t-set="taxes" t-value="', '.join(tax.tax_label for tax in line.tax_ids if tax.tax_label)"/>
                                    <td name="td_taxes" t-if="display_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }} {{ 'text-nowrap' if len(taxes) &lt; 10 else '' }}">
                                        <span t-if="not hide_prices" t-out="taxes" id="line_tax_ids">Tax 15%</span>
                                    </td>
                                    
                                    <td class="text-end o_price_total">
                                        <span t-if="not hide_prices" t-out="line.price_subtotal * (sign or 1)" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </t>

                                <t t-elif="is_section or is_subsection">
                                    <td colspan="99" t-att-class="padding_class">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>

                                <t t-elif="is_note">
                                    <td colspan="99" class="ps-5">
                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>
                            <!--
                            <tr t-if="is_product and line.product_id.invoice_name">
                                <td t-att-class="padding_class" colspan="99">
                                    <span t-field="line.product_id.invoice_name"/>
                                </td>
                            </tr>
                            -->
                        </t>
                    </t>
                </t>

            </tbody>
        </xpath>
    </template>
</odoo>