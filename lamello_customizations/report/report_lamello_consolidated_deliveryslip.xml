<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_lamello_consolidated_delivery_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-set="pickings" t-value="o.picking_ids"/>
                <t t-set="partner" t-value="pickings[:1].partner_id"/>
                <t t-set="o" t-value="o.with_context(lang=partner.lang or o.env.user.lang)"/>

                <t t-set="address">
                    <div name="div_outgoing_address">
                        <div name="outgoing_delivery_address" t-if="partner">
                            <strong>Käufer</strong>
                            <div t-out="partner"
                                t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                        </div>
                    </div>
                </t>
                <t t-set="information_block">
                    <div class="row">
                        <div class="col-7" name="div_incoming_address">
                            <div t-if="partner and partner != partner.commercial_partner_id" name="customer_address">
                                <strong>Customer</strong>
                            </div>
                            <div t-if="partner" name="partner_header">
                                <div t-field="partner.commercial_partner_id"
                                    t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True, "phone_icons": True}'/>
                            </div>
                        </div>
                    </div>
                </t>
                <div class="page">
                    <h2 style="margin-top: 15px;">
                        <span t-if="o.picking_type_id" t-out="o.picking_type_id._get_code_report_name()"/>
                        <span t-else="">Delivery Note</span>
                        <span t-field="o.name">BATCH/0001</span>
                    </h2>
                    <div class="oe_structure"></div>
                    <div id="informations" class="row mb-4">
                        <div t-if="pickings[:1].delivery_week" class="col-2 mb-2" name="div_delivery_week">
                            <strong>Woche<br/>Hét</strong>
                            <div t-field="pickings[0].delivery_week" class="m-0"/>
                        </div>
                        <div t-if="o.scheduled_date" class="col-3 mb-2" name="div_verladen_date">
                            <strong>Wurde verladen am<br/>Szállítás dátuma</strong>
                            <div t-field="o.scheduled_date" t-options='{"widget": "date"}' class="m-0"/>
                        </div>
                        <div class="col col-2 mw-100 mb-2">
                            <strong>Menge<br/>db</strong>
                            <div t-out="sum(pickings.mapped('total_qty'))" class="m-0">1</div>
                        </div>
                        <div t-if="sum(pickings.mapped('total_parcel_qty'))" class="col col-2 mw-100 mb-2">
                            <strong>Kolli<br/>Csomag</strong>
                            <div t-out="sum(pickings.mapped('total_parcel_qty'))" class="m-0">1</div>
                        </div>
                        <div t-if="sum(pickings.mapped('total_weight'))" class="col col-2 mw-100 mb-2">
                            <strong>Gesamtgewicht<br/>Összsúly</strong>
                            <div t-out="sum(pickings.mapped('total_weight'))" class="m-0">1</div>
                        </div>
                        <div t-if="sum(pickings.mapped('total_volume'))" class="col col-2 mw-100 mb-2">
                            <strong>m3<br/>m3 össz.</strong>
                            <div t-out="sum(pickings.mapped('total_volume'))" class="m-0">1</div>
                        </div>
                    </div>
                    <div class="oe_structure"></div>

                    <t t-set="format_number" t-value="lambda x: int(x) if x == int(x) else x"/>
                    <table class="table table-sm table-borderless" name="stock_move_line_table">
                        <thead>
                            <tr>
                                <th name="th_sml_product" style="width: 30%;">Produkt</th>
                                <th></th>
                                <th style="width: 100%;"></th>
                                <th name="th_sml_qty_ordered" class="text-end">Menge<br/>db</th>
                                <th name="th_sml_quantity" class="text-end">Kolli<br/>Csomag</th>
                            </tr>
                        </thead>

                        <tbody>

                            <!-- megrendelés szerint csoportosítva -->
                            <t t-set="orders_with_ref" t-value="o.move_line_ids.mapped('move_id.sale_line_id.order_id').filtered(lambda r: r.client_order_ref)"/>
                            <t t-foreach="orders_with_ref" t-as="order">
                                <tr class="o_line_section">
                                    <td colspan="99" class="bg-secondary" name="order_info">
                                        <span class="ms-1" t-field="order.client_order_ref"/>
                                    </td>
                                </tr>
                                <t t-set="order_move_lines" t-value="o.move_line_ids.filtered(lambda l: l.move_id.sale_line_id.order_id == order).sorted(key=lambda l: l.move_id.sale_line_id.sequence)"/>
                                <t t-foreach="order_move_lines" t-as="move_line">
                                    
                                    <tr>

                                        <t t-if="move_line.product_id.default_code and move_line.product_id.invoice_name">
                                            <td colspan="1">
                                                <t t-if="move_line.move_id.sale_line_id.linked_line_id">
                                                    <span>-- </span>
                                                </t>
                                                <span t-field="move_line.product_id.default_code"/>
                                            </td>
                                            <td colspan="2">
                                                <span t-field="move_line.product_id.invoice_name"/>
                                            </td>
                                        </t>
                                        <t t-elif="not move_line.product_id.default_code and move_line.product_id.invoice_name">
                                            <td colspan="1">
                                                <t t-if="move_line.move_id.sale_line_id.linked_line_id">
                                                    <span>-- </span>
                                                </t>
                                                <span t-field="move_line.product_id.product_tmpl_id.name"/>
                                            </td>
                                            <td colspan="2">
                                                <span t-field="move_line.product_id.invoice_name"/>
                                            </td>
                                        </t>
                                        <t t-else="">
                                            <td colspan="1">
                                                <t t-if="move_line.move_id.sale_line_id.linked_line_id">
                                                    <span>-- </span>
                                                </t>
                                                <span t-field="move_line.product_id.product_tmpl_id.name"/>
                                            </td>
                                            <td colspan="2"></td>
                                        </t>


                                        
                                        <td class="text-end"><span t-out="format_number(move_line.quantity)"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-out="format_number(move_line.line_parcel_qty)"/> 
                                        </td>
                                    </tr>
                                    
                                </t>
                            </t>

                            <!-- csoportosítás nélkül -->
                            <t t-set="no_ref_lines" t-value="o.move_line_ids.filtered(lambda l: not l.move_id.sale_line_id.order_id or not l.move_id.sale_line_id.order_id.client_order_ref)"/>
                            <t t-if="no_ref_lines">

                                <tr t-if="orders_with_ref">
                                    <td colspan="99" style="height: 20px;"></td>
                                </tr>
                                <t t-foreach="no_ref_lines" t-as="move_line">

                                    <tr>

                                        <t t-if="move_line.product_id.default_code and move_line.product_id.invoice_name">
                                            <td colspan="1">
                                                <t t-if="move_line.move_id.sale_line_id.linked_line_id">
                                                    <span>-- </span>
                                                </t>
                                                <span t-field="move_line.product_id.default_code"/>
                                            </td>
                                            <td colspan="2">
                                                <span t-field="move_line.product_id.invoice_name"/>
                                            </td>
                                        </t>
                                        <t t-elif="not move_line.product_id.default_code and move_line.product_id.invoice_name">
                                            <td colspan="1">
                                                <t t-if="move_line.move_id.sale_line_id.linked_line_id">
                                                    <span>-- </span>
                                                </t>
                                                <span t-field="move_line.product_id.product_tmpl_id.name"/>
                                            </td>
                                            <td colspan="2">
                                                <span t-field="move_line.product_id.invoice_name"/>
                                            </td>
                                        </t>
                                        <t t-else="">
                                            <td colspan="1">
                                                <t t-if="move_line.move_id.sale_line_id.linked_line_id">
                                                    <span>-- </span>
                                                </t>
                                                <span t-field="move_line.product_id.product_tmpl_id.name"/>
                                            </td>
                                            <td colspan="2"></td>
                                        </t>



                                        <td class="text-end"><span t-out="format_number(move_line.quantity)"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-out="format_number(move_line.line_parcel_qty)"/> 
                                        </td>
                                    </tr>

                                </t>
                            </t>
                        </tbody>
                    </table>
                    <br/>
                    <div class="oe_structure"></div>
                    <div t-if="o.note" name="batch_note" class="mt-3">
                        <div t-field="o.note"/>
                    </div>
                    <div class="oe_structure"></div>
                </div>
            </t>
        </t>
    </template>

    <template id="report_lamello_consolidated_deliveryslip">
        <t t-foreach="docs" t-as="o">
            <t t-call="lamello_customizations.report_lamello_consolidated_delivery_document"/>
        </t>
    </template>
</odoo>
