<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_lamello_report_picking" model="ir.actions.report">
            <field name="name">Lamello Picking Operations</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_lamello_picking</field>
            <field name="report_file">lamello_customizations.report_lamello_stockpicking_operations</field>
            <field name="print_report_name">'Picking Operations - %s - %s' % (object.partner_id.name or '', object.name)</field>
            <field name="binding_model_id" ref="model_stock_picking"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_lamello_report_delivery" model="ir.actions.report">
            <field name="name">Delivery Slip</field>
            <field name="model">stock.picking</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_lamello_deliveryslip</field>
            <field name="report_file">lamello_customizations.report_lamello_deliveryslip</field>
            <field name="print_report_name">'Delivery Slip - %s - %s' % (object.partner_id.name or '', object.name)</field>
            <field name="binding_model_id" ref="model_stock_picking"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_lamello_report_consolidated_delivery" model="ir.actions.report">
            <field name="name">Consolidated Delivery Note</field>
            <field name="model">stock.picking.batch</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_lamello_consolidated_deliveryslip</field>
            <field name="report_file">lamello_customizations.report_lamello_consolidated_deliveryslip</field>
            <field name="print_report_name">'Delivery Note - %s' % (object.name)</field>
        </record>

        <record id="action_report_mo_all_components" model="ir.actions.report">
            <field name="name">MO Komponens Lista</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_mo_components</field>
            <field name="report_file">lamello_customizations.report_mo_components</field>
            <field name="print_report_name">'MO_Komponensek'</field>
            <field name="binding_model_id" ref="mrp.model_mrp_production"/>
            <field name="binding_type">report</field>
        </record>

        <record id="paperformat_component_a5" model="report.paperformat">
            <field name="name">Alkatrészlista A5 formátum</field>
            <field name="default" eval="False"/>
            <field name="format">A5</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>

        <record id="action_report_component_list" model="ir.actions.report">
            <field name="name">Alkatrészlista (Tervezett)</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_component_template</field>
            <field name="report_file">lamello_customizations.report_component_template</field>
            <field name="print_report_name">'Alkatresz_lista_tervezett'</field>
            <field name="binding_model_id" eval="False"/>
            <field name="paperformat_id" ref="paperformat_component_a5"/>
        </record>

        <record id="action_report_component_list_demand" model="ir.actions.report">
            <field name="name">Alkatrészlista (Igény alapján)</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_component_template_demand</field>
            <field name="report_file">lamello_customizations.report_component_template_demand</field>
            <field name="print_report_name">'Alkatresz_lista_igeny'</field>
            <field name="binding_model_id" eval="False"/>
            <field name="paperformat_id" ref="paperformat_component_a5"/>
        </record>

        <record id="action_report_picking_list" model="ir.actions.report">
            <field name="name">Válogató lista (Tervezett)</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_picking_template</field>
            <field name="report_file">lamello_customizations.report_picking_template</field>
            <field name="print_report_name">'Valogato_lista_' + object.name</field>
            <field name="binding_model_id" eval="False"/> 
            <field name="paperformat_id" ref="paperformat_component_a5"/>
        </record>

        <record id="action_report_picking_list_demand" model="ir.actions.report">
            <field name="name">Válogató lista (Igény)</field>
            <field name="model">mrp.production</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">lamello_customizations.report_picking_template_demand</field>
            <field name="report_file">lamello_customizations.report_picking_template_demand</field>
            <field name="print_report_name">'Valogato_lista_' + object.name</field>
            <field name="binding_model_id" eval="False"/> 
            <field name="paperformat_id" ref="paperformat_component_a5"/>
        </record>

    </data>
</odoo>
