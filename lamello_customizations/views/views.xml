    <!-- product.template -->
    <record model="ir.ui.view" id="lamello_product_template_form">
      <field name="name">lamello.product.template.form</field>
      <field name="model">product.template</field>
      <field name="inherit_id" ref="product.product_template_form_view"/>
      <field name="arch" type="xml">
        <field name="categ_id" position="after">

          <field name="invoice_name"/>
          <field name="parcel_qty"/>
          <field name="component_code"/>
          <field name="product_codes" readonly="1"/>
          <field name="product_family_id"/>
          <field name="dimensions" readonly="1" invisible="product_variant_count != 1"/>
        </field>
      </field>
    </record>

    <!-- product.product -->
    <record model="ir.ui.view" id="lamello_product_product_form">
      <field name="name">lamello.product.product.form</field>
      <field name="model">product.product</field>
      <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='image_1920']" position="replace">
            <field name="image_variant_1920" 
                   widget="image" 
                   class="oe_avatar" 
                   options="{'zoom': True, 'convert_to_webp': True, 'preview_image': 'image_variant_128'}"/>
        </xpath>

        <field name="default_code" position="after">

          <field name="invoice_name"/>

          <field name="component_code"/>
          <field name="product_codes" readonly="1"/>        
          <!--
          <field name="seller_ids" widget="many2many_tags"/>          
          -->  
        </field>

        <xpath expr="//group[@name='weight']//div[field[@name='weight']]" position="after">
            <label for="parcel_qty"/>
            <div class="d-flex">
                <field name="parcel_qty" class="oe_inline"/>
            </div>
        </xpath>
        <xpath expr="//sheet/group[last()]" position="after">
          <separator string="Belső jegyzetek"/>
          <field name="description" placeholder="Írja ide a belső megjegyzéseket..." class="oe_inline"/>
        </xpath>
      </field>
    </record>


    <record id="product_product_kanban_view_inherit_codes" model="ir.ui.view">
        <field name="name">product.product.kanban.inherit.codes</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='color']" position="after">
                <field name="product_codes"/>
            </xpath>

            <xpath expr="//span[@t-if='record.default_code.value']" position="after">
                <div t-if="record.product_codes.raw_value" class="text-muted small italic">
                    <i class="fa fa-tags" title="Beszállítói termékkódok"/> 
                    <field name="product_codes"/>
                </div>
            </xpath>
        </field>
    </record>


    <record model="ir.ui.view" id="lamello_product_product_list">
      <field name="name">lamello.product.product.list</field>
      <field name="model">product.product</field>
      <field name="inherit_id" ref="product.product_product_tree_view"/>
      <field name="arch" type="xml">
        <field name="name" position="after">
          <field name="dimensions" optional="show"/>
          <field name="product_codes" optional="show" readonly="1"/>
          <!--
          <field name="seller_ids" widget="many2many_tags"/>
          -->
        </field>
      </field>
    </record>

    

    <!-- mrp.production -->
    <record model="ir.ui.view" id="lamello_mrp_production_form">
      <field name="name">lamello.mrp.production.form</field>
