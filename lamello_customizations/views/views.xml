<odoo>
  <data>

    <!-- sale.order -->
    <record model="ir.ui.view" id="lamello_sale_order_form">
      <field name="name">lamello.sale.order.form</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='commitment_date']" position="replace">
          <field name="commitment_date" invisible="1"/>
        </xpath>
        <field name="date_order" position="after">
          <!--
          <field name="delivery_year" readonly="state != 'draft'"/>
          -->
          <field name="client_order_ref"/>
          <field name="type"/>
          <field name="product_families" widget="many2many_tags"/>
          <field name="delivery_year"/>
          <field name="delivery_week"/>
          <!--
          <field name="sale_order_group_by_week_and_partner"/>
          -->
          <field name="commitment_date"/>          
        </field>
        
        <xpath expr="//field[@name='order_line']/list//field[@name='qty_invoiced']" position="after">
            <field name="parcel_qty"/>
        </xpath>

        <xpath expr="//field[@name='order_line']//list//field[@name='tax_ids']" position="attributes">
            <attribute name="width">40px</attribute>
        </xpath>

        <xpath expr="//field[@name='order_line']/list//field[@name='product_template_id']" position="after">
            <field name="invoice_name"/>
        </xpath>

        <xpath expr="//group[@name='sale_header']" position="after">
            <group name="arajanlat_beallitasok" string="Árajánlat beállítások">
                <field name="quotation_template_type"/>
            </group>
        </xpath>

      </field>
    </record>

    <record model="ir.ui.view" id="lamello_sale_order_tree">
      <field name="name">lamello.sale.order.tree</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.sale_order_tree"/>
      <field name="arch" type="xml">
        <field name="activity_ids" position="after">
          <field name="delivery_year"/>
          <field name="delivery_week"/>
          <field name="product_families" widget="many2many_tags"/>
        </field>
        <field name="company_id" position="after">
          <field name="type"/>
          <field name="client_order_ref"/>
          <field name="batch_id" widget="many2many_tags"/>
        </field>
      </field>
    </record>

    <record id="lamello_view_sales_order_filter" model="ir.ui.view">
      <field name="name">lamello.sale.order.filter</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_sales_order_filter"/>
      <field name="arch" type="xml">
        <filter name="my_sale_orders_filter" position="before">
          <filter name="filter_domestic" string="Hazai" domain="[('type', '=', 'domestic')]" help="Hazai rendelések"/>
          <filter name="filter_export" string="Export" domain="[('type', '=', 'export')]" help="Export rendelések"/>
        </filter>
      </field>
    </record>


    <!-- stock.picking -->
    <record model="ir.ui.view" id="lamello_stock_picking_form">
      <field name="name">lamello.picking.form</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_form"/>
      <field name="arch" type="xml">
        <!--
        <xpath expr="//button[@name='%(stock.action_report_delivery)d']" position="attributes">
            <attribute name="invisible">state == 'done' and picking_type_code == 'outgoing'</attribute>
        </xpath>
        -->
        <!--
        <xpath expr="//button[@name='%(stock.action_report_delivery)d']" position="after">
        -->
        <!--
            <button name="action_print_delivery_slip" 
                    string="Print" 
                    invisible="state != 'done' or picking_type_code != 'outgoing'" 
                    type="object" 
                    groups="base.group_user" 
                    data-hotkey="o"/>
                    -->
                    <!--
            <button name="action_custom_create_invoice" 
                    string="Számla létrehozása" 
                    type="object" 
                    class="oe_highlight" 
                    invisible="picking_type_code != 'outgoing' or state != 'done' or invoiced"
                    groups="base.group_user" 
                    confirm="Biztosan létre szeretnéd hozni a számlát a kiszállított mennyiségek alapján?"/>
                    -->
        <!--
        </xpath>
        -->

        <field name="origin" position="after">
          <field name="lamello_batch_id" readonly="1" invisible="picking_type_code != 'internal'"/>
          <field name="delivery_year" invisible="picking_type_code != 'outgoing'"/>
          <field name="delivery_week" invisible="picking_type_code != 'outgoing'"/>
          <field name="type" invisible="picking_type_code != 'outgoing'"/>
        </field>
<!--
        <xpath expr="//sheet/group/group[2]" position="after">
          <group name="szallito_beallitasok" string="Szállítólevél beállítások" invisible="state != 'done' and picking_type_code != 'outgoing'">
            <field name="delivery_slip_type"/>
          </group>
        </xpath>
    -->    
        <xpath expr="//field[@name='picking_properties']" position="before">
          <group name="szallito_beallitasok" string="Szállítólevél beállítások" invisible="state != 'done' and picking_type_code != 'outgoing'">
            <field name="delivery_slip_type"/>
          </group>
        </xpath>

        <xpath expr="//field[@name='move_ids']//field[@name='quantity']" position="before">
          <field name="parcel_qty" column_invisible="parent.picking_type_code != 'outgoing'"/>
        </xpath>

        <xpath expr="//field[@name='move_ids']//list/field[@name='product_id']" position="after">
          <field name="invoice_name" column_invisible="parent.picking_type_code != 'outgoing'"/>
        </xpath>
      </field>

    </record>

    <!-- stock.picking.batch -->
    <record model="ir.ui.view" id="lamello_stock_picking_batch_form">
      <field name="name">lamello.picking.batch.form</field>
      <field name="model">stock.picking.batch</field>
      <field name="inherit_id" ref="stock_picking_batch.stock_picking_batch_form"/>
      <field name="arch" type="xml">
        <button name="action_open_label_layout" position="after">
          <button name="action_print_consolidated_delivery_note" string="Print Consolidated Delivery Note" type="object" data-hotkey="shift+p"/>
        </button>
        <xpath expr="//notebook" position="after">
          <field name="note" placeholder="Notes..."/>
        </xpath>
      </field>
    </record>

    <!-- stock.move.line list inside batch detailed operations -->
    <record model="ir.ui.view" id="lamello_stock_move_line_batch_list">
      <field name="name">lamello.stock.move.line.batch.list</field>
      <field name="model">stock.move.line</field>
      <field name="inherit_id" ref="stock_picking_batch.view_move_line_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='product_id']" position="after">
          <field name="invoice_name" optional="show"/>
        </xpath>
      </field>
    </record>

