            (0, 0, {'view_mode': 'form', 'view_id': ref('stock.view_picking_form')})]"/>
    </record>

    <!-- egyedi internal list megnyitása, az invetory modulban kanban nézeten ready gomb -->
    <record id="action_lamello_picking_tree_ready_internal" model="ir.actions.act_window">
        <field name="name">To Do</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,kanban,form,calendar</field>
        <field name="domain"></field>
        <field name="context">{'contact_display': 'partner_address', 'search_default_available': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('lamello_stock_picking_tree_internal')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('stock.view_picking_form')})]"/>
    </record>

