          <field name="name">mrp.component.group.tree</field>
          <field name="model">mrp.component.group</field>
          <field name="arch" type="xml">
              <list>
                  <field name="sequence" widget="handle"/>
                  <field name="name"/>
              </list>
          </field>
      </record>

      <record id="view_mrp_component_group_form" model="ir.ui.view">
          <field name="name">mrp.component.group.form</field>
