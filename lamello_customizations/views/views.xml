          <field name="arch" type="xml">
              <form>
                  <sheet>
                      <!-- Fejléc adatok -->
                      <div class="oe_title">
                          <label for="name" string="Csoport neve"/>
                          <h1>
                              <field name="name" placeholder="Pl. Fenekek"/>
