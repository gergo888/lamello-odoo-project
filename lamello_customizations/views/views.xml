        </xpath>

        <xpath expr="//field[@name='invoice_line_ids']//list/field[@name='product_id']" position="after">
            <field name="invoice_name" column_invisible="parent.move_type not in ('out_invoice', 'out_refund')"/>
        </xpath>
      </field>
    </record>
  

    <!-- res.company -->
