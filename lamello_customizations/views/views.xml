                              </field>
                          </page>
                          <page string="Kulcsszavak (Név alapján)" name="keywords">
                              <field name="keyword_ids">
                                  <list editable="bottom">
                                      <field name="name" string="Kulcsszó"/>
                                  </list>
                              </field>
                          </page>
                      </notebook>
                  </sheet>
              </form>
          </field>
      </record>

      <record id="action_mrp_component_group" model="ir.actions.act_window">
