            <button name="action_manufacture_and_store_components" string="Alkatrészek gyártása és tárolása" type="object" class="btn-secondary"/>
            <!--
            <button name="action_store_components" string="Alkatrészek tárolása" type="object" class="btn-secondary"/>
            -->
          </header>
          <sheet>
            <div class="oe_title">
              <h1>
                <field name="name" readonly="True"/>
              </h1>
            </div>
            <group>
              <field name="delivery_year"/>
              <field name="delivery_week"/>
              <field name="number"/>
              <field name="color"/>
              <field name="product_family_id"/>
              <field name="active" invisible="1"/>
            </group>
            <notebook>
              
              <page string="Értékesíthető termékek" name="sale_orders">
                  <field name="sale_mo_ids" widget="many2many" context="{'default_batch_id': id}">
                      <list editable="bottom">
                          <field name="name" readonly="1"/>
                          <field name="product_id" domain="[('sale_ok', '=', True)]" readonly="1"/>
                          <field name="product_qty" readonly="1"/>
                          <field name="state" string="Állapot" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" readonly="1"/>
                          <field name="is_filtered_pick" string="Raktári kiadás csoportosítása"/>
                          <button name="action_open_form" type="object" icon="fa-external-link" title="Megnyitás"/>
                      </list>
                  </field>
              </page>

              <page string="Félkész termékek / Alkatrészek" name="non_sale_orders">
                  <field name="non_sale_mo_ids" widget="many2many" context="{'default_batch_id': id}">
                      <list>
                          <field name="name"/>
                          <field name="product_id" domain="[('sale_ok', '=', False)]"/>
                          <field name="product_qty"/>
                          <field name="state" string="Állapot" widget="badge"/>
                      </list>
                  </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
  </record>

  <record model="ir.ui.view" id="lamello_batch_list">
    <field name="name">lamello.batch.list</field>
    <field name="model">lamello.batch</field>
    <field name="arch" type="xml">
      <list string="Ütemek">
        <field name="name" width="20%"/>
        <field name="delivery_year" width="16%"/>
        <field name="delivery_week" width="16%"/>
        <field name="number" width="16%"/>
        <field name="color" width="16%"/>
        <field name="product_family_id" width="16%"/>
      </list>
    </field>
  </record>

      <record id="view_sale_order_line_simplified_tree" model="ir.ui.view">
        <field name="name">sale.order.line.simplified.tree</field>
        <field name="model">sale.order.line</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_id"/>
                <field name="order_partner_id"/>
                <field name="product_id"/>
                <field name="product_uom_qty"/>
                <!--
                <field name="product_size_x"/>
                <field name="product_size_y"/>
                <field name="product_size_z"/>
                -->
                <field name="product_template_attribute_value_ids" 
                   widget="many2many_tags" 
                   string="Attribútumok"/>
            </list>
        </field>
    </record>

