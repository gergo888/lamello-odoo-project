          <field name="res_model">mrp.component.group</field>
          <field name="view_mode">list,form</field>
      </record>


    <!-- Wizard Form View -->
    <record id="view_lamello_batch_mo_wizard_form" model="ir.ui.view">
        <field name="name">lamello.batch.mo.wizard.form</field>
        <field name="model">lamello.batch.mo.wizard</field>
        <field name="arch" type="xml">
            <form string="Gyártási megrendelések létrehozása rendelések alapján">
                <field name="batch_id" invisible="1"/>
                <group>
                    <field name="batch_id" readonly="1" string="Ütem"/>
                </group>
                <separator string="Megrendelés tételek"/>
                
                <field name="delivery_year" invisible="1"/>
                <field name="delivery_week" invisible="1"/>
                <field name="product_family_id" invisible="1"/>
                <field name="color" invisible="1"/>

                <field name="sale_order_line_ids"
                   widget="many2many"
                   domain="[
                        ('order_id.state', 'in', ['sale', 'done']),
                        ('product_id.type', '=', 'consu'),
                        ('order_id.delivery_year', '=', delivery_year),
                        ('order_id.delivery_week', '=', delivery_week),
                        ('batch_id', '=', False),
                        ('order_id.has_manufacturing_order', '=', False),
                        ('product_id.sale_ok', '=', True),
                        ('product_id.product_tmpl_id.purchase_ok', '=', False)
                   ] + ([('product_id.product_tmpl_id.product_family_id', '=', product_family_id)] if product_family_id else [])"
                   context="{
                    'tree_view_ref': 'view_sale_order_line_simplified_tree',
                    'dialog_size': 'extra-large'
                    }">
                    <list>
                        <field name="order_id" string="Rendelés"/>
                        <field name="product_id" string="Termék"/>
                        <field name="product_uom_qty" string="Mennyiség"/>
                        <field name="product_uom_id" string="Egység"/>
                        <field name="state" string="Állapot"/>
                    </list>
                </field>
                <footer>
                    <button
                        name="action_create_manufacturing_orders"
                        string="Létrehozás"
                        type="object"
                        class="btn-primary"
                    />
                    <button string="Mégse" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Internal picking search: Kiadandó filter -->
    <record id="lamello_picking_internal_search" model="ir.ui.view">
      <field name="name">lamello.stock.picking.internal.search</field>
      <field name="model">stock.picking</field>
      <field name="inherit_id" ref="stock.view_picking_internal_search"/>
      <field name="arch" type="xml">
        <filter name="available" position="after">
          <separator/>
          <filter name="kiadando" string="Kiadandó"
                  domain="[('move_ids.product_id.purchase_ok', '=', True), ('state', 'not in', ('done', 'cancel'))]"
                  help="Vásárolt termékeket tartalmazó szállítmányok"/>
        </filter>
      </field>
    </record>

    <!-- MRP search -->
    <record id="lamello_mrp_filter" model="ir.ui.view">
      <field name="name">lamello.mrp.filter</field>
      <field name="model">mrp.production</field>
      <field name="inherit_id" ref="mrp.view_mrp_production_filter"/>
      <field name="arch" type="xml">
        <filter name="filter_to_close" position="after">
          <filter name="filter_sale" string="Késztermékek" domain="[('product_id.sale_ok', '=', True)]" help="Eladható termékek"/>
          <filter name="filter_not_sale" string="Félkész termékek" domain="[('product_id.sale_ok', '=', False)]" help="Nem eladható termékek"/>
        </filter>
      </field>
    </record>

